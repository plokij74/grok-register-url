{
  "// === 代理配置 ===": "",
  "proxy": "http://127.0.0.1:7890",
  "proxies": [],
  "proxies_file": "proxies.txt",
  "use_proxy": true,
  "proxy_mode": "clash",
  "proxy_pick_mode": "random",
  "proxy_fail_threshold": 3,
  "proxy_blacklist_hours": 24,
  "proxy_blacklist_file": "proxy_blacklist.json",
  "proxy_retry_per_account": 0,
  "proxy_connect_timeout": 12,
  "proxy_read_timeout": 25,
  "proxy_via_local": "auto",
  "proxy_chain_local": "http://127.0.0.1:7890",
  "proxy_chain_host_keywords": [
    "711proxy",
    "rotgb",
    "kookeey",
    "gate.kookeey",
    "iproyal",
    "proxyrack"
  ],
  "// === 注册配置 ===": "",
  "register_count": 1,
  "register_threads": 1,
  "turnstile_browser_reuse": true,
  "// 每个浏览器窗口内并行过盾的标签页数（worker 映射到 窗口+标签）": "",
  "browser_pages_per_window": 3,
  "// === 浏览器后端 ===": "",
  "// local = 系统 Chrome | roxy = Roxy 指纹浏览器": "",
  "browser_backend": "local",
  "roxy_api_base": "http://127.0.0.1:50000",
  "roxy_api_token": "",
  "roxy_workspace_id": "",
  "roxy_project_id": "",
  "roxy_reuse_window": true,
  "roxy_delete_on_stop": false,
  "roxy_clear_data_on_reuse": true,
  "// false=整批复用窗口；true=每个账号重启 Roxy（旧行为，更慢）": "",
  "roxy_refresh_each_account": false,
  "roxy_headless": false,
  "roxy_window_name_prefix": "grokx-ts",
  "roxy_timeout_sec": 60,
  "roxy_random_fingerprint": true,
  "roxy_use_proxy_manager": false,
  "roxy_proxy_only_checked": false,
  "// === Cloudflare 临时邮箱 ===": "",
  "cloudflare_api_base": "",
  "cloudflare_api_key": "",
  "default_domains": [],
  "// === Turnstile 验证 ===": "",
  "turnstile_sitekey": "0x4AAAAAAAhr9JGVDZbrZOo0",
  "turnstile_token": "",
  "capsolver_api_key": "",
  "turnstile_browser": true,
  "turnstile_headless": false,
  "turnstile_timeout_sec": 90,
  "turnstile_page_wait_sec": 1.0,
  "turnstile_api_poll_sec": 0.3,
  "turnstile_paint_wait_sec": 0.5,
  "turnstile_poll_interval_sec": 0.35,
  "turnstile_click_interval_sec": 0.8,
  "turnstile_rerender_wait_sec": 0.5,
  "// === 输出 ===": "",
  "output_file": "accounts.json",
  "save_sso": true,
  "print_sso": false,
  "// === 资料 ===": "",
  "set_tos_on_create": false,
  "tos_accepted_version": 1,
  "given_name": "John",
  "family_name": "Doe",
  "// === CPA 导出 ===": "",
  "cpa_export_enabled": true,
  "cpa_auth_dir": "cpa_auths",
  "cpa_base_url": "https://cli-chat-proxy.grok.com/v1",
  "cpa_include_password": false,
  "cpa_force_remint": false,
  "// === CPA 推送到远程 CLIProxyAPI ===": "",
  "cpa_push_enabled": false,
  "cpa_push_base_url": "",
  "cpa_push_api_key": "",
  "// === Mint ===": "",
  "mint_proxy": "",
  "mint_timeout_sec": 90,
  "cpa_push_retries": 3,
  "cpa_push_timeout_sec": 30,
  "register_max_attempts": 0
